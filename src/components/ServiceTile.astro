---
/**
 * ServiceTile — full-bleed section in Apple store style.
 * `surface` selects background; no border-radius; vertical padding scales on mobile.
 */
interface Props {
  surface?: 'canvas' | 'parchment' | 'tile-1' | 'tile-2' | 'tile-3' | 'ink';
  id?: string;
  ariaLabel?: string;
}

const { surface = 'canvas', id, ariaLabel } = Astro.props;

const bg = {
  canvas: 'bg-canvas text-ink',
  parchment: 'bg-canvas-parchment text-ink',
  'tile-1': 'bg-surface-tile-1 text-canvas',
  'tile-2': 'bg-surface-tile-2 text-canvas',
  'tile-3': 'bg-surface-tile-3 text-canvas',
  ink: 'bg-ink text-canvas',
}[surface];
---

<section id={id} aria-label={ariaLabel} class={`w-full ${bg}`}>
  <div class="py-12 md:py-20 px-4 md:px-8">
    <slot />
  </div>
</section>
