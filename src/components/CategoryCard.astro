---
import { categoryPath } from '@/utils/links';
interface Props {
  slug: string;
  title: string;
  description: string;
  icon: string;
  itineraryCount: number;
}
const { slug, title, description, icon, itineraryCount } = Astro.props;
const href = categoryPath(slug);
---

<a
  href={href}
  class="block bg-canvas border border-hairline rounded-lg p-6 no-underline h-full transition-colors duration-200 hover:border-ink-muted-40"
>
  <div class="text-3xl mb-3" aria-hidden="true">{icon}</div>
  <h3 class="text-body-strong text-ink">{title}</h3>
  <p class="mt-2 text-body text-ink-muted-80">{description}</p>
  <div class="mt-4 text-caption text-primary">
    {itineraryCount}
    {itineraryCount === 1 ? 'itinerary' : 'itineraries'} →
  </div>
</a>
