---
/**
 * SmartImage — preferred <img> wrapper for flyed.
 *
 * Why not <Image> from astro:assets? Our content collections reference images
 * by URL string (frontmatter fields like heroImage). astro:assets requires
 * imported modules so it can hash them, which doesn't compose with
 * data-driven paths like /images/destinations/{slug}.jpg.
 *
 * Instead: keep assets in /public/images, set explicit width/height to avoid
 * CLS, loading="lazy" by default, decoding="async", and use srcset for the
 * most common widths (400/800/1200/1600) so browsers pick the right one.
 *
 * Use <SmartImage> when you don't know the dimensions at the call site, or
 * <img width height loading decoding> directly when you do.
 */

interface Props {
  src: string;
  alt: string;
  width: number;
  height: number;
  loading?: 'lazy' | 'eager';
  fetchpriority?: 'high' | 'low' | 'auto';
  class?: string;
  /** Pre-defined width variants for srcset. Defaults to common responsive widths. */
  variants?: number[];
  /** Round to nearest viewport width. */
  sizes?: string;
}

const {
  src,
  alt,
  width,
  height,
  loading = 'lazy',
  fetchpriority = 'auto',
  class: className = '',
  variants = [400, 800, 1200, 1600],
  sizes = '(max-width: 768px) 100vw, (max-width: 1200px) 50vw, 33vw',
} = Astro.props;

// Build srcset from Unsplash CDN-style images; for local /public/images
// we just point at the same file (no resize pipeline wired in this MVP).
const isRemote = src.startsWith('http');
const buildSrc = (variantWidth: number) => {
  if (isRemote && src.includes('images.unsplash.com')) {
    return src.replace(/([?&])w=\d+/, `$1w=${variantWidth}`);
  }
  return src;
};

const srcset = variants.map((v) => `${buildSrc(v)} ${v}w`).join(', ');
---

<img
  src={buildSrc(width)}
  srcset={srcset}
  sizes={sizes}
  alt={alt}
  width={width}
  height={height}
  loading={loading}
  decoding="async"
  fetchpriority={fetchpriority}
  class={className}
/>