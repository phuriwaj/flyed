---
interface Props {
  quote: string;
  author: string;
  role: string;
  school: string;
  city?: string;
  country?: string;
}
const { quote, author, role, school, city, country } = Astro.props;
const location = city && country ? `${school} · ${city}, ${country}` : school;
---

<figure class="bg-surface-tile-2 p-6 rounded-lg h-full flex flex-col border border-divider-soft/10">
  <blockquote class="text-canvas flex-1">
    <p class="text-lead-airy leading-snug">&ldquo;{quote}&rdquo;</p>
  </blockquote>
  <figcaption class="mt-4 text-caption-strong text-canvas">
    <div class="text-body-strong text-canvas">{author}</div>
    <div class="text-caption text-canvas/80">{role}</div>
    <div class="text-fine-print text-canvas/60">{location}</div>
  </figcaption>
</figure>
