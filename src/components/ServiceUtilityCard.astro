---
import { Image } from 'astro:assets';

interface Props {
  href: string;
  imageSrc: string;
  imageAlt: string;
  title: string;
  meta?: string;
  cta?: string;
  class?: string;
}

const { href, imageSrc, imageAlt, title, meta, cta, class: className = '' } = Astro.props;
---

<a
  href={href}
  class={`group block bg-canvas border border-hairline rounded-lg p-6 no-underline transition-shadow duration-200 hover:border-ink-muted-40 ${className}`}
>
  <div class="aspect-square w-full overflow-hidden rounded-sm bg-canvas-parchment mb-4">
    <!-- format/widths omitted: imageService=passthrough + public/* src → no build-time variants. Re-add after image-migration follow-up lands. -->
    <Image
      src={imageSrc}
      alt={imageAlt}
      width={720}
      height={720}
      sizes="(min-width: 1024px) 240px, (min-width: 640px) 33vw, 50vw"
      class="w-full h-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
    />
  </div>
  <h3 class="text-body-strong text-ink mb-1">{title}</h3>
  {meta && <p class="text-body text-ink-muted-80 mb-3">{meta}</p>}
  {cta && <span class="text-caption text-primary group-hover:underline">{cta} →</span>}
</a>
