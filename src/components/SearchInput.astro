---
interface Props {
  name?: string;
  placeholder?: string;
  value?: string;
  class?: string;
  ariaLabel?: string;
}

const {
  name = 'q',
  placeholder = 'Search',
  value = '',
  class: className = '',
  ariaLabel = placeholder,
} = Astro.props;
---

<form role="search" class={`relative ${className}`}>
  <span
    class="pointer-events-none absolute left-5 top-1/2 -translate-y-1/2 text-ink-muted-60"
    aria-hidden="true"
  >
    <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
      <path
        d="M5.5 1a4.5 4.5 0 1 1-3.18 7.68l-1.95 1.95a.5.5 0 0 1-.77-.62l.07-.08 1.95-1.95A4.5 4.5 0 0 1 5.5 1Zm0 1a3.5 3.5 0 1 0 0 7 3.5 3.5 0 0 0 0-7Z"
        fill="currentColor"></path>
    </svg>
  </span>
  <input
    type="search"
    name={name}
    value={value}
    placeholder={placeholder}
    aria-label={ariaLabel}
    class="w-full h-11 pl-12 pr-5 rounded-pill bg-canvas text-body text-ink placeholder:text-ink-muted-40 border border-[rgba(0,0,0,0.08)] focus:outline-none focus:border-primary transition-colors duration-150"
  />
</form>
