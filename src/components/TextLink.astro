---
interface Props {
  href: string;
  underline?: 'always' | 'hover' | 'never';
  class?: string;
  ariaLabel?: string;
}

const { href, underline = 'hover', class: className = '', ariaLabel } = Astro.props;
const deco =
  underline === 'always'
    ? 'underline'
    : underline === 'never'
      ? 'no-underline'
      : 'no-underline hover:underline';
const base = `text-primary hover:text-primary-hover transition-colors duration-150 ${deco}`;
const cls = `${base} ${className}`;
---

<a href={href} class={cls} aria-label={ariaLabel}><slot /></a>
