---
interface Badge {
  name: string;
  imageSrc: string;
  href?: string;
}
interface Props {
  badges: Badge[];
}
const { badges } = Astro.props;
---

<div class="flex flex-wrap items-center justify-center gap-8 opacity-70">
  {
    badges.map((b) => (
      <a
        href={b.href ?? '#'}
        class="grayscale hover:grayscale-0 transition opacity-90 hover:opacity-100"
        aria-label={b.name}
      >
        <img
          src={b.imageSrc}
          alt={b.name}
          class="h-12 w-auto"
          loading="lazy"
          decoding="async"
          width={48}
          height={48}
        />
      </a>
    ))
  }
</div>
