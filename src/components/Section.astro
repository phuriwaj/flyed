---
interface Props {
  bg?: 'canvas' | 'parchment' | 'tile-1';
  id?: string;
  class?: string;
}

const { bg = 'canvas', id, class: className = '' } = Astro.props;
const bgClass = {
  canvas: 'bg-canvas text-ink',
  parchment: 'bg-canvas-parchment text-ink',
  'tile-1': 'bg-surface-tile-1 text-canvas',
}[bg];
---

<section id={id} class={`py-12 md:py-20 ${bgClass} ${className}`}>
  <div class="max-w-6xl mx-auto px-4 md:px-8">
    <slot />
  </div>
</section>
