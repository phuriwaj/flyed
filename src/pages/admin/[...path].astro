---
// Admin catch-all: serves the Decap CMS shell at any /admin/* path.
// Marked prerender = false so the Worker renders it at request time rather
// than requiring getStaticPaths() under output: 'static'. Phase 1 Task 1.6
// will replace this with public/admin/index.html and remove the catch-all.
export const prerender = false;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex,nofollow" />
    <title>flyed CMS</title>
    <link rel="icon" href="/favicon.svg" />
    <style>
      body { font-family: system-ui, sans-serif; margin: 0; }
    </style>
  </head>
  <body>
    <!-- Decap CMS bundle from CDN. Pin to 3.7.x. -->
    <script is:inline src="https://unpkg.com/decap-cms@^3.7.0/dist/decap-cms.js"></script>
  </body>
</html>
