---
export const prerender = true;
import PageLayout from '@/layouts/PageLayout.astro';
export const locale = 'th';
const isTh = true;
---

<PageLayout title="ไม่พบหน้า" description="404" noindex>
  <section class="py-32 text-center max-w-2xl mx-auto px-4">
    <h1 class="font-display text-6xl font-semibold text-teak-900">404</h1>
    <p class="mt-4 text-xl text-teak-700">ไม่พบหน้าที่คุณกำลังมองหา</p>
    <a href="/th" class="mt-8 inline-block bg-sunset-600 hover:bg-sunset-400 text-rice-50 font-medium px-6 py-3 rounded-md no-underline">
      กลับหน้าแรก
    </a>
  </section>
</PageLayout>
