# Cloudflare Pages redirects
# https://developers.cloudflare.com/pages/configuration/redirects/

# Specific API catches first (must precede catch-all)
/api/* /api/:splat 200

# /admin: map to the static shell. Cloudflare Pages auto-serves
# /admin/index.html for /admin and /admin/ (directory index). Without
# the explicit /admin rule, the trailing-slash rule below would redirect
# /admin <-> /admin/ infinitely.
/admin /admin/index.html 200

# Trailing slash removal (specific)
/*/ /:splat 301

# Legacy paths
/about-us /about 301
/contact-us /contact 301

# Blog pagination page 1 → blog root
/blog/1 /blog 301
/th/blog/1 /th/blog 301
# (No catch-all 404 redirect — Cloudflare Pages serves /404.html from
# src/pages/404.astro automatically for unmatched paths)

# Decap CMS admin: served as a static asset from public/admin/index.html
# (Workers serves it from the ASSETS binding; no Worker function invocation
# for the shell HTML). No SPA fallback redirect is needed — visiting /admin
# resolves to /admin/index.html directly. Nested /admin/foo/bar paths do
# not auto-fall back to /admin/index.html under the Workers static-asset
# binding, so only /admin and /admin/index.html are reachable.