# Cloudflare Pages redirects
# https://developers.cloudflare.com/pages/configuration/redirects/

# Specific API catches first (must precede catch-all)
/api/* /api/:splat 200

# Trailing slash removal (specific)
/*/ /:splat 301

# Legacy paths
/about-us /about 301
/contact-us /contact 301

# Blog pagination page 1 → blog root
/blog/1 /blog 301
/th/blog/1 /th/blog 301
# (No catch-all 404 redirect — Cloudflare Pages serves /404.html from
# src/pages/404.astro automatically for unmatched paths)

# Decap CMS admin: served by the Worker from src/pages/admin/[...path].astro
# (which renders the same HTML the SPA fallback would have served). Workers
# routes /admin/* via the catch-all in the Astro adapter, so no static
# redirect rule is needed and Workers' stricter _redirects parser would
# reject it as an infinite loop.